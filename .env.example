# Socket.IO Server URL
# Local development:
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
# Render production (update with your Render server URL):
# NEXT_PUBLIC_SOCKET_URL=https://climaneer-server.onrender.com

# ── AI Voice Command Parser (Optional) ──
# Set one of these to enable AI-powered natural language command understanding:
#
# Option 1: Google Gemini
# Get a free API key at https://aistudio.google.com/
# NEXT_PUBLIC_AI_PROVIDER=gemini
# NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key
# NEXT_PUBLIC_AI_MODEL=gemini-2.0-flash-lite
#
# Option 2: OpenRouter (access to GPT-4o, Claude, etc.)
# Sign up at https://openrouter.ai/
# NEXT_PUBLIC_AI_PROVIDER=openrouter
# NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-your-key
# NEXT_PUBLIC_AI_MODEL=openai/gpt-4o-mini
